generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int               @id @default(autoincrement())
  openid      String            @unique
  unionid     String?           @unique
  phone       String?           @unique
  avatar      String?
  nickname    String?
  gender      Int               @default(0)
  birthday    DateTime?
  height      Int?
  weight      Int?
  goal        String?
  role        Int               @default(1)
  isVerified  Boolean           @default(false)
  level       Int               @default(1)
  status      Int               @default(1)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  deletedAt   DateTime?         @map("deleted_at")
  bookings    Booking[]
  checkins    Checkin[]
  coach       Coach?
  application CoachApplication?

  @@index([openid])
  @@index([phone])
  @@map("users")
}

model Coach {
  id            Int     @id @default(autoincrement())
  userId        Int     @unique
  name          String
  avatar        String?
  gender        Int     @default(0)
  experience    Int     @default(0)
  specialty     String?
  description   String?
  certificates  String?
  rating        Decimal @default(5.000000000000000000000000000000)
  totalSessions Int     @default(0)
  price         Int     @default(0)

  // 认证相关字段
  verificationStatus Int       @default(0) // 0-未认证，1-认证中，2-已认证，3-已拒绝
  verificationReason String? // 审核拒绝原因
  verifiedAt         DateTime? // 认证通过时间
  reviewedBy         Int? // 审核管理员 ID
  reviewedAt         DateTime? // 审核时间

  // 补充信息
  phone          String?
  birthday       DateTime?
  workExperience String? // JSON 字符串
  achievements   String? // JSON 字符串

  status        Int             @default(1)
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  deletedAt     DateTime?       @map("deleted_at")
  bookings      Booking[]
  schedules     CoachSchedule[]
  user          User            @relation(fields: [userId], references: [id])
  courses       Course[]
  reviews       Review[]
  trainingPlans TrainingPlan[]

  @@index([userId])
  @@index([status])
  @@index([verificationStatus])
  @@map("coaches")
}

model Course {
  id          Int       @id @default(autoincrement())
  coachId     Int
  name        String
  type        Int
  duration    Int
  price       Int
  description String?
  cover       String?
  maxStudents Int       @default(1)
  status      Int       @default(1)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  bookings    Booking[]
  coach       Coach     @relation(fields: [coachId], references: [id])

  @@index([coachId])
  @@index([type])
  @@index([status])
  @@map("courses")
}

model Booking {
  id           Int       @id @default(autoincrement())
  userId       Int
  coachId      Int
  courseId     Int
  startTime    DateTime
  endTime      DateTime
  status       Int       @default(0)
  note         String?
  cancelReason String?
  totalPrice   Int
  paidAmount   Int       @default(0)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  coach        Coach     @relation(fields: [coachId], references: [id])
  course       Course    @relation(fields: [courseId], references: [id])
  user         User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([coachId])
  @@index([status])
  @@index([startTime])
  @@index([courseId], map: "bookings_courseId_fkey")
  @@map("bookings")
}

model Checkin {
  id        Int       @id @default(autoincrement())
  userId    Int
  type      Int
  content   String
  images    String?
  duration  Int?
  calories  Int?
  weight    Decimal?
  mood      Int?
  likes     Int       @default(0)
  comments  Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("checkins")
}

model CoachSchedule {
  id          Int      @id @default(autoincrement())
  coachId     Int
  dayOfWeek   Int
  startTime   String
  endTime     String
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  coach       Coach    @relation(fields: [coachId], references: [id])

  @@index([coachId])
  @@map("coach_schedules")
}

model Review {
  id          Int       @id @default(autoincrement())
  userId      Int
  coachId     Int
  bookingId   Int?
  rating      Int
  content     String?
  images      String?
  isAnonymous Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  coach       Coach     @relation(fields: [coachId], references: [id])

  @@index([coachId])
  @@index([userId])
  @@index([rating])
  @@map("reviews")
}

model TrainingPlan {
  id          Int       @id @default(autoincrement())
  coachId     Int
  name        String
  description String?
  goals       String
  difficulty  Int       @default(1)
  duration    Int
  exercises   Json
  isPublic    Boolean   @default(false)
  status      Int       @default(1)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  coach       Coach     @relation(fields: [coachId], references: [id])

  @@index([coachId])
  @@index([status])
  @@map("training_plans")
}

model StudentCoach {
  id          Int       @id @default(autoincrement())
  studentId   Int
  coachId     Int
  courseCount Int       @default(0)
  usedCount   Int       @default(0)
  startDate   DateTime
  endDate     DateTime?
  status      Int       @default(1)
  note        String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@index([studentId])
  @@index([coachId])
  @@index([status])
  @@map("student_coaches")
}

model UserCoach {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  coachId   Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([coachId])
  @@map("user_coaches")
}

model CoachApplication {
  id             Int       @id @default(autoincrement())
  userId         Int       @unique
  name           String
  phone          String
  avatar         String?
  gender         Int       @default(0)
  birthday       DateTime?
  specialty      String?
  experience     Int       @default(0)
  description    String?
  price          Int       @default(0)
  certificates   String? // JSON 字符串
  workExperience String? // JSON 字符串
  achievements   String? // JSON 字符串
  status         Int       @default(0) // 0-待审核，1-通过，2-拒绝
  reason         String? // 拒绝原因
  reviewedBy     Int? // 审核管理员 ID
  reviewedAt     DateTime?
  submittedAt    DateTime  @default(now())
  user           User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("coach_applications")
}
