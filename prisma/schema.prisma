generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int               @id @default(autoincrement())
  openid      String            @unique
  unionid     String?           @unique
  phone       String?           @unique
  avatar      String?
  nickname    String?
  gender      Int               @default(0)
  birthday    DateTime?
  height      Int?
  weight      Int?
  goal        String?
  role        Int               @default(1)
  isVerified  Boolean           @default(false)
  level       Int               @default(1)
  status      Int               @default(1)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  deletedAt   DateTime?         @map("deleted_at")
  bookings    Booking[]
  checkins    Checkin[]
  coach       Coach?
  application CoachApplication?
  reviewedApplications CoachApplication[] @relation("ApplicationReviewer")
  notifications Notification[]

  @@index([openid])
  @@index([phone])
  @@map("users")
}

model Coach {
  id            Int     @id @default(autoincrement())
  userId        Int     @unique
  name          String
  avatar        String?
  gender        Int     @default(0)
  experience    Int     @default(0)
  specialty     String?
  description   String?
  certificates  String?
  rating        Decimal @default(5.000000000000000000000000000000)
  totalSessions Int     @default(0)
  price         Int     @default(0)

  // 认证相关字段
  verificationStatus Int       @default(0) // 0-未认证，1-认证中，2-已认证，3-已拒绝
  verificationReason String? // 审核拒绝原因
  verifiedAt         DateTime? // 认证通过时间
  reviewedBy         Int? // 审核管理员 ID
  reviewedAt         DateTime? // 审核时间

  // 补充信息
  phone          String?
  birthday       DateTime?
  workExperience String? // JSON 字符串
  achievements   String? // JSON 字符串

  // 学员管理相关
  maxStudents    Int     @default(50)  // 最大学员数
  activeStudents Int    @default(0)   // 活跃学员数

  status        Int             @default(1)
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  deletedAt     DateTime?       @map("deleted_at")
  bookings      Booking[]
  schedules     CoachSchedule[]
  user          User            @relation(fields: [userId], references: [id])
  courses       Course[]
  reviews       Review[]
  trainingPlans TrainingPlan[]
  students      Student[]
  coursePackages StudentCoursePackage[]
  sessions      CourseSession[]
  templates     CourseTemplate[]

  @@index([userId])
  @@index([status])
  @@index([verificationStatus])
  @@map("coaches")
}

model Course {
  id          Int       @id @default(autoincrement())
  coachId     Int
  name        String
  type        Int
  duration    Int
  price       Int
  description String?
  cover       String?
  maxStudents Int       @default(1)
  status      Int       @default(1)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  bookings    Booking[]
  coach       Coach     @relation(fields: [coachId], references: [id])

  @@index([coachId])
  @@index([type])
  @@index([status])
  @@map("courses")
}

model Booking {
  id           Int       @id @default(autoincrement())
  userId       Int
  coachId      Int
  courseId     Int
  startTime    DateTime
  endTime      DateTime
  status       Int       @default(0)
  note         String?
  cancelReason String?
  totalPrice   Int
  paidAmount   Int       @default(0)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  coach        Coach     @relation(fields: [coachId], references: [id])
  course       Course    @relation(fields: [courseId], references: [id])
  user         User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([coachId])
  @@index([status])
  @@index([startTime])
  @@index([courseId], map: "bookings_courseId_fkey")
  @@map("bookings")
}

model Checkin {
  id        Int       @id @default(autoincrement())
  userId    Int
  type      Int
  content   String
  images    String?
  duration  Int?
  calories  Int?
  weight    Decimal?
  mood      Int?
  likes     Int       @default(0)
  comments  Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("checkins")
}

model CoachSchedule {
  id          Int      @id @default(autoincrement())
  coachId     Int
  dayOfWeek   Int
  startTime   String
  endTime     String
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  coach       Coach    @relation(fields: [coachId], references: [id])

  @@index([coachId])
  @@map("coach_schedules")
}

model Review {
  id          Int       @id @default(autoincrement())
  userId      Int
  coachId     Int
  bookingId   Int?
  rating      Int
  content     String?
  images      String?
  isAnonymous Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  coach       Coach     @relation(fields: [coachId], references: [id])

  @@index([coachId])
  @@index([userId])
  @@index([rating])
  @@map("reviews")
}

model TrainingPlan {
  id          Int       @id @default(autoincrement())
  coachId     Int
  name        String
  description String?
  goals       String
  difficulty  Int       @default(1)
  duration    Int
  exercises   Json
  isPublic    Boolean   @default(false)
  status      Int       @default(1)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  coach       Coach     @relation(fields: [coachId], references: [id])

  @@index([coachId])
  @@index([status])
  @@map("training_plans")
}

model StudentCoach {
  id          Int       @id @default(autoincrement())
  studentId   Int
  coachId     Int
  courseCount Int       @default(0)
  usedCount   Int       @default(0)
  startDate   DateTime
  endDate     DateTime?
  status      Int       @default(1)
  note        String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@index([studentId])
  @@index([coachId])
  @@index([status])
  @@map("student_coaches")
}

model UserCoach {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  coachId   Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([coachId])
  @@map("user_coaches")
}

model CoachApplication {
  id             Int       @id @default(autoincrement())
  userId         Int       @unique
  name           String
  phone          String
  avatar         String?
  gender         Int       @default(0)
  birthday       DateTime?
  specialty      String?
  experience     Int       @default(0)
  description    String?
  price          Int       @default(0)
  certificates   String? // JSON 字符串
  workExperience String? // JSON 字符串
  achievements   String? // JSON 字符串
  status         Int       @default(0) // 0-待审核，1-通过，2-拒绝
  reason         String? // 拒绝原因
  reviewedBy     Int? // 审核管理员 ID
  reviewedAt     DateTime?
  submittedAt    DateTime  @default(now())
  user           User      @relation(fields: [userId], references: [id])
  reviewer       User?     @relation("ApplicationReviewer", fields: [reviewedBy], references: [id])

  @@index([userId])
  @@index([status])
  @@map("coach_applications")
}

model Notification {
  id          Int      @id @default(autoincrement())
  userId      Int      // 接收用户 ID
  title       String   // 消息标题
  content     String   // 消息内容
  type        String   // 消息类型：system, booking, checkin, certification
  templateId  String?  // 微信模板 ID
  data        Json?    // 模板数据
  isRead      Boolean  @default(false)
  readAt      DateTime?
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isRead])
  @@index([type])
  @@index([createdAt])
  @@map("notifications")
}

// ========== 学员管理相关模型 ==========

// 学员表（独立于注册用户，教练可手动创建）
model Student {
  id            Int       @id @default(autoincrement())
  coachId       Int                          // 所属教练
  name          String                       // 学员姓名
  phone         String?                      // 手机号
  gender        Int       @default(0)        // 0-未知，1-男，2-女
  birthday      DateTime?                    // 生日
  height        Int?                         // 身高 (cm)
  weight        Decimal?                     // 体重 (kg)
  goal          String?                      // 训练目标
  note          String?                      // 教练备注
  avatar        String?                      // 头像
  status        Int       @default(1)        // 1-活跃，0-非活跃
  inviteCode    String?   @unique            // 邀请码
  userId        Int?      @unique            // 关联的微信用户 ID
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  
  // 关系
  coach         Coach           @relation(fields: [coachId], references: [id])
  coursePackages StudentCoursePackage[]
  sessions      CourseSession[]
  weightRecords WeightRecord[]
  
  @@index([coachId])
  @@index([status])
  @@map("students")
}

// 学员课时包表
model StudentCoursePackage {
  id                Int       @id @default(autoincrement())
  studentId         Int                          // 学员 ID
  coachId           Int                          // 教练 ID
  courseName        String                       // 课程名称
  totalSessions     Int                          // 总课时
  usedSessions      Int       @default(0)        // 已消耗课时
  remainingSessions Int                          // 剩余课时
  price             Int                          // 价格（分）
  purchaseDate      DateTime                     // 购买日期
  expireDate        DateTime?                    // 过期日期
  status            Int       @default(1)        // 1-有效，0-过期/用完
  note              String?                      // 备注
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime? @map("deleted_at")
  
  // 关系
  student       Student         @relation(fields: [studentId], references: [id])
  coach         Coach           @relation(fields: [coachId], references: [id])
  sessions      CourseSession[]
  
  @@index([studentId])
  @@index([coachId])
  @@index([status])
  @@map("student_course_packages")
}

// 课程会话表（具体的每次课程）
model CourseSession {
  id            Int       @id @default(autoincrement())
  coachId       Int                          // 教练 ID
  studentId     Int                          // 学员 ID
  packageId     Int?                         // 关联的课时包 ID
  startTime     DateTime                     // 开始时间
  endTime       DateTime                     // 结束时间
  duration      Int                          // 时长（分钟）
  status        Int       @default(0)        // 0-待上课，1-已完成，2-已取消，3-已爽约
  courseType    String?                      // 课程类型
  trainContent  String?                      // 训练内容（JSON 字符串）
  studentState  String?                      // 学员状态
  coachNote     String?                      // 教练备注/下次建议
  images        String?                      // 课程照片（JSON 数组）
  isDeducted    Boolean   @default(false)    // 是否已扣课时
  cancelReason  String?                      // 取消原因
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  
  // 关系
  coach         Coach           @relation(fields: [coachId], references: [id])
  student       Student         @relation(fields: [studentId], references: [id])
  package       StudentCoursePackage? @relation(fields: [packageId], references: [id])
  
  @@index([coachId])
  @@index([studentId])
  @@index([status])
  @@index([startTime])
  @@map("course_sessions")
}

// 体重记录表
model WeightRecord {
  id            Int       @id @default(autoincrement())
  studentId     Int                          // 学员 ID
  weight        Decimal                      // 体重 (kg)
  bodyFat       Decimal?                     // 体脂率 (%)
  muscleMass    Decimal?                     // 肌肉量 (kg)
  note          String?                      // 备注
  recordDate    DateTime                     // 记录日期
  createdAt     DateTime  @default(now())
  deletedAt     DateTime?
  
  // 关系
  student       Student         @relation(fields: [studentId], references: [id])
  
  @@index([studentId])
  @@index([recordDate])
  @@map("weight_records")
}

// 课程模板表
model CourseTemplate {
  id            Int       @id @default(autoincrement())
  coachId       Int                          // 教练 ID
  name          String                       // 模板名称
  courseType    String                       // 课程类型
  duration      Int                          // 预计时长（分钟）
  exercises     Json                         // 训练动作（JSON 数组）
  description   String?                      // 描述
  isPublic      Boolean   @default(false)    // 是否公开
  usageCount    Int       @default(0)        // 使用次数
  status        Int       @default(1)        // 1-启用，0-禁用
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  
  // 关系
  coach         Coach           @relation(fields: [coachId], references: [id])
  
  @@index([coachId])
  @@index([status])
  @@map("course_templates")
}
